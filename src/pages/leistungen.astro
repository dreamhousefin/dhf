---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const title = 'Leistungen';
const description = 'Professionelle Immobilienvermittlung und Immobilienfinanzierung in Bremen. Dreamhouse Finance begleitet Sie vom ersten Schritt bis zur Schlüsselübergabe.';
---

<Layout title={title} description={description}>
  <Header slot="header" />
  
  <!-- ========================================
       PAGE HERO
       ======================================== -->
  <section class="relative bg-slate-50 py-20 lg:py-28" aria-labelledby="page-heading">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
        Unsere Expertise
      </span>
      <h1 id="page-heading" class="text-4xl lg:text-5xl font-bold text-slate-800 mb-6">
        Leistungen
      </h1>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        Ob Immobilienvermittlung oder Finanzierung – wir bieten Ihnen den kompletten Service aus einer Hand. Persönlich, unabhängig und mit jahrelanger Erfahrung.
      </p>
    </div>
  </section>
  
  <!-- ========================================
       IMMOBILIENMAKLERIN SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="makler-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-light text-primary rounded-lg mb-6">
            <i class="fa-solid fa-building" aria-hidden="true"></i>
            <span class="font-semibold">Immobilienmaklerin</span>
          </div>
          
          <h2 id="makler-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-6">
            Ihre Traumimmobilie in Bremen finden
          </h2>
          
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            Als zertifizierte Immobilienmaklerin kenne ich den Bremer Markt wie meine Westentasche. Mit Zugang zu exklusiven Angeboten und einem großen Netzwerk helfe ich Ihnen, genau die Immobilie zu finden, die zu Ihnen passt.
          </p>
          
          <!-- Features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Exklusive Angebote</strong>
                <p class="text-slate-600 text-sm">Zugang zu Immobilien, die nicht öffentlich ausgeschrieben werden</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Professionelle Bewertung</strong>
                <p class="text-slate-600 text-sm">Fundierte Analyse von Kaufpreisen und Marktwerten</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Begleitung bei Besichtigungen</strong>
                <p class="text-slate-600 text-sm">Gemeinsame Besichtigungen mit fachkundiger Beratung vor Ort</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Vertragsabwicklung</strong>
                <p class="text-slate-600 text-sm">Unterstützung bei Kaufvertrag und Notartermin</p>
              </div>
            </li>
          </ul>
          
          <a 
            href="/kontakt/"
            class="btn-premium inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-lg transition-colors"
          >
            Immobilie suchen
            <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
          </a>
        </div>
        
        <!-- Image -->
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl bg-slate-200">
            <img 
              src="/images/leistung1.jpeg"
              alt="Esperanza Weiher Muñoz - Professionelle Finanzierungsberatung"
              class="w-full h-full object-cover object-[center_25%]"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       FINANZIERUNG SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-slate-50" aria-labelledby="finanzierung-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image (Left on Desktop) -->
        <div class="relative order-2 lg:order-1">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl bg-slate-200">
            <img 
              src="/images/leistung2.png"
              alt="Finanzierungsunterlagen und Rechner - Immobilienfinanzierung"
              class="w-full h-full object-cover"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
        </div>
        
        <!-- Content -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-light text-primary rounded-lg mb-6">
            <i class="fa-solid fa-wallet" aria-hidden="true"></i>
            <span class="font-semibold">Immobilienfinanzierung</span>
          </div>
          
          <h2 id="finanzierung-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-6">
            Die beste Finanzierung für Ihr Vorhaben
          </h2>
          
          <p class="text-lg text-slate-600 leading-relaxed mb-8">
            Als gelernte Rechtsanwalts- und Notarfachangestellte mit IHK-Sachkunde nach § 34i GewO finde ich für Sie die optimale Finanzierungslösung. Unabhängig, transparent und mit den besten Konditionen – durch ein starkes Bankennetzwerk.
          </p>
          
          <!-- Features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Starkes Bankennetzwerk</strong>
                <p class="text-slate-600 text-sm">Vergleich über ein breites Netzwerk von Banken und Versicherungen</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Individuelle Beratung</strong>
                <p class="text-slate-600 text-sm">Maßgeschneiderte Lösungen für Ihre persönliche Lebenssituation</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Zinsbindungsstrategie</strong>
                <p class="text-slate-600 text-sm">Optimale Zinsbindungsfrist für langfristige Planungssicherheit</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-primary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                <i class="fa-solid fa-check text-xs text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <strong class="text-slate-800">Baukindergeld & Fördermittel</strong>
                <p class="text-slate-600 text-sm">Beantragung aller verfügbaren Fördermittel für Sie</p>
              </div>
            </li>
          </ul>
          
          <a 
            href="/kontakt/"
            class="btn-premium inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-lg transition-colors"
          >
            Finanzierung planen
            <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       BENEFITS GRID
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="benefits-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
          Ihre Vorteile
        </span>
        <h2 id="benefits-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-4">
          Warum Dreamhouse Finance?
        </h2>
        <p class="text-lg text-slate-600">
          Die Kombination aus Immobilienvermittlung und Finanzierung macht den Unterschied.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Benefit 1 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-clock text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Zeitersparnis</h3>
          <p class="text-slate-600 text-sm">Ein Ansprechpartner für alles – von der Suche bis zur Finanzierung.</p>
        </div>
        
        <!-- Benefit 2 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-shield-halved text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Unabhängigkeit</h3>
          <p class="text-slate-600 text-sm">Wir sind nicht an eine Bank gebunden und finden das beste Angebot für Sie.</p>
        </div>
        
        <!-- Benefit 3 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-coins text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Beste Konditionen</h3>
          <p class="text-slate-600 text-sm">Durch unser großes Banknetzwerk erhalten Sie die besten Zinssätze.</p>
        </div>
        
        <!-- Benefit 4 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-user-tie text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Persönliche Beratung</h3>
          <p class="text-slate-600 text-sm">Keine Callcenter – direkter Kontakt zu Esperanza Weiher Muñoz.</p>
        </div>
        
        <!-- Benefit 5 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-map-location-dot text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Lokale Expertise</h3>
          <p class="text-slate-600 text-sm">Fundierte Kenntnis des Bremer Immobilienmarktes und der Region.</p>
        </div>
        
        <!-- Benefit 6 -->
        <div class="p-6 rounded-xl bg-slate-50 hover:bg-slate-100 transition-colors">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <i class="fa-solid fa-house-chimney text-2xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-lg font-semibold text-slate-800 mb-2">Rundum-Betreuung</h3>
          <p class="text-slate-600 text-sm">Vom ersten Gespräch bis zur Schlüsselübergabe an Ihrer Seite.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       CTA SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-primary" aria-labelledby="cta-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Lassen Sie uns zusammenarbeiten
      </h2>
      <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">
        Vereinbaren Sie ein kostenloses Erstgespräch und erfahren Sie, wie wir Ihnen helfen können.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/kontakt/"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-primary font-semibold rounded-lg transition-all duration-300 shadow-lg"
        >
          <i class="fa-regular fa-calendar-check" aria-hidden="true"></i>
          Zeit für dein Eigentum - Unverbindlich beraten lassen
        </a>
        <a 
          href="tel:01622894304"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary-hover text-white font-semibold rounded-lg border-2 border-white/30 hover:bg-primary transition-all duration-300"
        >
          <i class="fa-solid fa-phone" aria-hidden="true"></i>
          Anrufen
        </a>
      </div>
    </div>
  </section>
  
  <Footer slot="footer" />
  <CookieBanner slot="cookie-banner" />
  <WhatsAppButton slot="whatsapp" />
</Layout>
