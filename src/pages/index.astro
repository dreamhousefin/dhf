---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessStep from '../components/ProcessStep.astro';

const title = 'Dreamhouse Finance';
const description = 'Ihre Immobilienmaklerin und Finanzierungsexpertin in Bremen. Traumimmobilie finden und finanzieren – alles aus einer Hand. Esperanza Weiher Muñoz berät Sie persönlich und unabhängig.';
---

<Layout title={title} description={description}>
  <Header slot="header" />
  
  <!-- ========================================
       HERO SECTION
       ======================================== -->
  <section class="relative bg-slate-50 overflow-hidden" aria-labelledby="hero-heading">
    <!-- Background Decoration -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div class="text-center lg:text-left">
          <h1 id="hero-heading" class="text-4xl lg:text-5xl xl:text-6xl font-bold text-slate-800 leading-tight mb-6">
            Traumimmobilie & <span class="text-primary">Finanzierung</span> aus einer Hand
          </h1>
          <p class="text-lg lg:text-xl text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto lg:mx-0">
            Als Immobilienmaklerin und Finanzierungsexpertin begleite ich Sie auf dem Weg zu Ihrem Eigenheim – persönlich, unabhängig und mit rechtlicher Expertise in Bremen.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a 
              href="/kontakt/"
              class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary text-white font-semibold rounded-lg transition-all duration-300 shadow-soft hover:shadow-lg"
              aria-label="Kostenlose Beratung vereinbaren"
            >
              <i class="fa-regular fa-calendar-check" aria-hidden="true"></i>
              Zeit für dein Eigentum - Erstgespräch vereinbaren
            </a>
            <a 
              href="tel:01622894304"
              class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-slate-700 font-semibold rounded-lg border-2 border-slate-200 hover:border-primary hover:text-primary transition-all duration-300"
              aria-label="Jetzt anrufen: 0162 2894304"
            >
              <i class="fa-solid fa-phone" aria-hidden="true"></i>
              0162 2894304
            </a>
          </div>
          
          <!-- Trust Badge -->
          <div class="mt-8 flex items-center justify-center lg:justify-start gap-6 text-sm text-slate-500">
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-check text-primary" aria-hidden="true"></i>
              <span>Kostenlose Erstberatung</span>
            </div>
            <div class="flex items-center gap-2">
              <i class="fa-solid fa-check text-primary" aria-hidden="true"></i>
              <span>Unabhängig & Persönlich</span>
            </div>
          </div>
        </div>
        
        <!-- Hero Image -->
        <div class="relative">
          <div class="relative aspect-[4/3] lg:aspect-square rounded-2xl overflow-hidden shadow-xl bg-slate-200">
            <!-- Hero Image -->
            <img 
              src="/images/hero.jpeg"
              alt="Modernes Einfamilienhaus mit Garten - repräsentiert die Traumimmobilie"
              class="w-full h-full object-cover object-[90%_center]"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="800"
              height="800"
            />
            <!-- Overlay Badge -->
            <div class="absolute bottom-6 left-6 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center">
                  <i class="fa-solid fa-check text-2xl text-white" aria-hidden="true"></i>
                </div>
                <div>
                  <p class="font-semibold text-slate-800">Persönliche Beratung</p>
                  <p class="text-sm text-slate-500">Strukturiert & transparent</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       TRUST LOGOS
       ======================================== -->
  <section class="py-12 bg-white border-b border-slate-100" aria-labelledby="trust-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="trust-heading" class="text-center text-sm font-medium text-slate-500 uppercase tracking-wider mb-8">
        Vertrauen durch Professionalität
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center opacity-60">
        <!-- Trust Indicators -->
        <div class="flex flex-col items-center gap-2 text-center">
          <i class="fa-solid fa-shield-halved text-3xl text-slate-400" aria-hidden="true"></i>
          <span class="text-sm font-medium text-slate-600">Geprüfte Qualität</span>
        </div>
        <div class="flex flex-col items-center gap-2 text-center">
          <i class="fa-solid fa-user-group text-3xl text-slate-400" aria-hidden="true"></i>
          <span class="text-sm font-medium text-slate-600">Persönliche Beratung</span>
        </div>
        <div class="flex flex-col items-center gap-2 text-center">
          <i class="fa-solid fa-clock text-3xl text-slate-400" aria-hidden="true"></i>
          <span class="text-sm font-medium text-slate-600">Schnelle Bearbeitung</span>
        </div>
        <div class="flex flex-col items-center gap-2 text-center">
          <i class="fa-solid fa-star text-3xl text-slate-400" aria-hidden="true"></i>
          <span class="text-sm font-medium text-slate-600">Zertifiziert</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       SERVICES SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="services-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
          Unsere Leistungen
        </span>
        <h2 id="services-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-4">
          Alles aus einer Hand für Ihre Immobilie
        </h2>
        <p class="text-lg text-slate-600">
          Von der Immobiliensuche bis zur Finanzierung – wir begleiten Sie durch den gesamten Prozess mit persönlicher Expertise.
        </p>
      </div>
      
      <!-- Service Cards -->
      <div class="grid md:grid-cols-3 gap-8">
        <ServiceCard 
          title="Immobilienmaklerin"
          description="Finden Sie Ihre Traumimmobilie in Bremen und Umgebung. Mit persönlicher Beratung und Zugang zu exklusiven Angeboten."
          icon="home"
          href="/leistungen/"
        />
        <ServiceCard 
          title="Immobilienfinanzierung"
          description="Optimale Finanzierungslösungen von über 500 Banken. Wir finden die beste Kondition für Ihre persönliche Situation."
          icon="chart"
          href="/leistungen/"
        />
        <ServiceCard 
          title="Rundum-Service"
          description="Von der ersten Besichtigung bis zur Schlüsselübergabe – wir kümmern uns um alles. Inklusive Notar- und Behördengänge."
          icon="handshake"
          href="/leistungen/"
        />
      </div>
    </div>
  </section>
  
  <!-- ========================================
       ABOUT SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-slate-50" aria-labelledby="about-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image -->
        <div class="relative">
          <div class="aspect-[3/4] max-w-md mx-auto lg:mx-0 rounded-2xl overflow-hidden shadow-xl bg-slate-200">
            <!-- Portrait -->
            <img 
              src="/images/ubermich.jpeg"
              alt="Esperanza Weiher Muñoz - Inhaberin von Dreamhouse Finance"
              class="w-full h-full object-cover object-[center_20%]"
              loading="lazy"
              width="600"
              height="800"
            />
          </div>
          <!-- Decorative Element -->
          <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-primary/10 rounded-full -z-10" aria-hidden="true"></div>
          <div class="absolute -top-6 -left-6 w-32 h-32 bg-primary/10 rounded-full -z-10" aria-hidden="true"></div>
        </div>
        
        <!-- Content -->
        <div>
          <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
            Über die Inhaberin
          </span>
          <h2 id="about-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-6">
            Esperanza Weiher Muñoz
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            Ich begleite Menschen in Bremen und Umgebung auf dem Weg ins Eigenheim. Strukturiert, transparent und verständlich – damit Sie sich sicher fühlen und Eigentum planbar wird.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Als gelernte Rechtsanwalts- und Notarfachangestellte kenne ich die Abläufe, die Verträge und die Details, auf die es wirklich ankommt. Mit meiner IHK-Sachkunde nach § 34i GewO sowie § 34c GewO verbinde ich rechtliche Sicherheit mit moderner, lösungsorientierter Beratung.
          </p>
          
          <!-- Stats -->
          <div class="grid grid-cols-2 gap-6 mb-8">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-network-wired text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <div class="text-lg font-bold text-slate-800">Starkes Netzwerk</div>
                <div class="text-sm text-slate-600">Zahlreiche Kunden</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-scale-balanced text-primary" aria-hidden="true"></i>
              </div>
              <div>
                <div class="text-lg font-bold text-slate-800">Rechtlich versiert</div>
                <div class="text-sm text-slate-600">Rechtsanwalts- & Notarerfahrung</div>
              </div>
            </div>
          </div>
          
          <a 
            href="/ueber-uns/"
            class="btn-premium inline-flex items-center gap-2 px-6 py-3 bg-slate-800 text-white font-medium rounded-lg transition-colors hover:bg-slate-700"
            aria-label="Mehr über Esperanza Weiher Muñoz erfahren"
          >
            Mehr über mich
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       PROCESS SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="process-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
          So funktioniert's
        </span>
        <h2 id="process-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-4">
          Drei Schritte zu Ihrer Traumimmobilie
        </h2>
        <p class="text-lg text-slate-600">
          Unkompliziert, transparent und persönlich. So einfach läuft die Zusammenarbeit mit uns ab.
        </p>
      </div>
      
      <!-- Process Steps -->
      <div class="max-w-2xl mx-auto">
        <ProcessStep 
          number={1}
          title="Kostenloses Erstgespräch"
          description="In einem persönlichen Gespräch besprechen wir Ihre Wünsche, Ihre finanzielle Situation und die Möglichkeiten. Hier legen wir gemeinsam die Basis für Ihren Erfolg."
        />
        <ProcessStep 
          number={2}
          title="Immobiliensuche & Finanzierung"
          description="Wir suchen passende Immobilien für Sie und prüfen parallel die optimale Finanzierungsstruktur. Mit Zugang zu exklusiven Angeboten und einem starken Bankennetzwerk."
        />
        <ProcessStep 
          number={3}
          title="Begleitung bis zur Übergabe"
          description="Von der Besichtigung über das Angebot bis zur Schlüsselübergabe – wir sind an Ihrer Seite. Inklusive aller Abstimmungen mit Notaren, Banken und Behörden."
          isLast={true}
        />
      </div>
    </div>
  </section>
  
  <!-- ========================================
       TESTIMONIAL SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-slate-50" aria-labelledby="testimonial-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-12">
          <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
            Kundenstimmen
          </span>
          <h2 id="testimonial-heading" class="text-3xl lg:text-4xl font-bold text-slate-800">
            Was unsere Kunden sagen
          </h2>
        </div>
        
        <!-- Testimonial Card -->
        <blockquote class="relative bg-white rounded-2xl shadow-card p-8 lg:p-12">
          <!-- Quote Icon -->
          <div class="absolute top-8 left-8 text-primary/20" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-16 h-16">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </div>
          
          <div class="relative pt-8">
            <p class="text-xl lg:text-2xl text-slate-700 leading-relaxed mb-8 italic">
              "Frau Weiher Muñoz hat uns von A bis Z begleitet. Die Finanzierung war komplex, aber sie hat alles verständlich erklärt und die beste Lösung gefunden. Wir sind unglaublich dankbar!"
            </p>
            
            <footer class="flex items-center gap-4">
              <div class="w-14 h-14 bg-primary-light rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-primary">
                  <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <cite class="not-italic font-semibold text-slate-800">Familie Schmidt</cite>
                <p class="text-slate-500 text-sm">Eigentümer in Bremen-Horn</p>
              </div>
            </footer>
          </div>
        </blockquote>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       CALCULATOR CTA SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-primary-light" aria-labelledby="calc-cta-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-white">
          <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h2 id="calc-cta-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-6">
        Berechnen Sie Ihre Finanzierung
      </h2>
      <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
        Nutzen Sie unsere kostenlosen Online-Rechner für eine erste Orientierung. 
        Von Budgetrechner bis Zinsvergleich – alles an einem Ort.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/rechner/"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
          aria-label="Zu den Rechnern"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" clip-rule="evenodd" />
          </svg>
          Zu den Rechnern
        </a>
        <a 
          href="/kontakt/"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-slate-700 font-semibold rounded-lg border-2 border-slate-200 hover:border-primary hover:text-primary transition-all duration-300"
          aria-label="Persönliche Beratung vereinbaren"
        >
          Persönliche Beratung
        </a>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       CTA SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-slate-900" aria-labelledby="cta-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="text-3xl lg:text-4xl font-bold text-white mb-6">
        Bereit für Ihre Traumimmobilie?
      </h2>
      <p class="text-xl text-slate-300 mb-10 max-w-2xl mx-auto">
        Vereinbaren Sie jetzt Ihr kostenloses Erstgespräch. Gemeinsam finden wir die beste Lösung für Ihre persönliche Situation.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/kontakt/"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
          aria-label="Beratungstermin vereinbaren"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z" clip-rule="evenodd" />
          </svg>
          Beratungstermin vereinbaren
        </a>
        <a 
          href={`https://wa.me/491622894304`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-premium inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-slate-800 font-semibold rounded-lg hover:bg-slate-100 transition-all duration-300"
          aria-label="Über WhatsApp schreiben"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#25D366]">
            <path fill-rule="evenodd" d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10a9.96 9.96 0 01-4.874-1.266L2.89 22l1.324-4.098A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2zm0 1.5a8.5 8.5 0 00-8.5 8.5c0 1.986.682 3.815 1.824 5.264l.22.277-.92 2.844 2.928-.948.272.166A8.47 8.47 0 0012 20.5a8.5 8.5 0 000-17z" clip-rule="evenodd" />
          </svg>
          Über WhatsApp schreiben
        </a>
      </div>
      
      <p class="mt-6 text-slate-400 text-sm">
        Oder rufen Sie direkt an: <a href="tel:01622894304" class="text-white hover:text-primary transition-colors">0162 2894304</a>
      </p>
    </div>
  </section>
  
  <Footer slot="footer" />
  <CookieBanner slot="cookie-banner" />
  <WhatsAppButton slot="whatsapp" />
</Layout>
