---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const title = 'Über Uns';
const description = 'Lernen Sie Esperanza Weiher Muñoz kennen – Ihre Immobilienmaklerin und Finanzierungsexpertin in Bremen. Erfahren Sie mehr über die Philosophie von Dreamhouse Finance.';
---

<Layout title={title} description={description}>
  <Header slot="header" />
  
  <!-- ========================================
       PAGE HERO
       ======================================== -->
  <section class="relative bg-slate-50 py-20 lg:py-28" aria-labelledby="page-heading">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
          Unser Team
        </span>
        <h1 id="page-heading" class="text-4xl lg:text-5xl font-bold text-slate-800 mb-6">
          Über Dreamhouse Finance
        </h1>
        <p class="text-xl text-slate-600">
          Bei Dreamhouse Finance geht es mir nicht um Standardlösungen, sondern um einen klaren, verlässlichen Prozess.
        </p>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       ABOUT OWNER SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="owner-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image -->
        <div class="relative">
          <div class="aspect-[3/4] max-w-md mx-auto lg:mx-0 rounded-2xl overflow-hidden shadow-xl bg-slate-200">
            <img 
              src="/images/ubermich.jpeg"
              alt="Esperanza Weiher Muñoz - Inhaberin und Geschäftsführerin von Dreamhouse Finance"
              class="w-full h-full object-cover object-[center_20%]"
              loading="lazy"
              width="600"
              height="800"
            />
          </div>
          
          <!-- Stats Card -->
          <div class="absolute -bottom-6 -right-6 lg:right-auto lg:-left-6 bg-white rounded-xl shadow-lg p-6 max-w-xs">
            <div class="grid grid-cols-1 gap-4 text-center">
              <div class="flex items-center gap-3 justify-center">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary">
                    <path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497 4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 20.25a4.49 4.49 0 01-3.397-1.549 4.49 4.49 0 01-3.498-1.306 4.491 4.491 0 01-1.307-3.498A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 000-1.06l-3-3a.75.75 0 10-1.06 1.06l1.72 1.72H8.25a.75.75 0 000 1.5h5.69l-1.72 1.72a.75.75 0 101.06 1.06l3-3z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="text-left">
                  <div class="text-xl font-bold text-primary">Starkes Netzwerk</div>
                  <div class="text-sm text-slate-600">Zahlreiche Kunden</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Decorative Elements -->
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-primary/10 rounded-full -z-10" aria-hidden="true"></div>
          <div class="absolute -bottom-8 right-12 w-32 h-32 bg-primary/5 rounded-full -z-10" aria-hidden="true"></div>
        </div>
        
        <!-- Content -->
        <div>
          <h2 id="owner-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-2">
            Esperanza Weiher Muñoz
          </h2>
          <p class="text-primary font-medium text-lg mb-6">Gründerin & Geschäftsführerin</p>
          
          <div class="space-y-4 text-slate-600 leading-relaxed">
            <p>
              Ich begleite Menschen in Bremen und Umgebung auf dem Weg ins Eigenheim. Strukturiert, transparent und verständlich – damit Sie sich sicher fühlen und Eigentum planbar wird.
            </p>
            <p>
              Als <strong class="text-slate-800">gelernte Rechtsanwalts- und Notarfachangestellte</strong> kenne ich die Abläufe, die Verträge und die Details, auf die es wirklich ankommt. Mit meiner IHK-Sachkunde nach § 34i GewO sowie § 34c GewO verbinde ich rechtliche Sicherheit mit moderner, lösungsorientierter Beratung.
            </p>
            <p>
              Bei Dreamhouse Finance geht es mir nicht um Standardlösungen, sondern um einen klaren, verlässlichen Prozess. Ich unterstütze Sie bei der Immobilienfinanzierung, berate Sie transparent zu Ihren Möglichkeiten und begleite auf Wunsch auch die Vermarktung Ihrer Immobilie.
            </p>
            <p>
              Ich nehme Ihnen Komplexität ab, bringe Struktur in Unterlagen und Entscheidungen und bleibe als fester Ansprechpartner an Ihrer Seite – damit der Weg zum Eigentum planbar wird und Sie am Ende <strong class="text-slate-800">Zeit für Ihr Eigentum</strong> haben.
            </p>
            <p>
              Am Ende steht nicht nur eine Finanzierung oder eine Immobilie – sondern das, was zählt: Zeit für dein Eigentum.
            </p>
          </div>
          
          <!-- Signature -->
          <div class="mt-8 pt-8 border-t border-slate-100">
            <p class="font-handwriting text-2xl text-slate-800 italic">Esperanza Weiher Muñoz</p>
            <p class="text-slate-500 text-sm mt-1">Inhaberin, Dreamhouse Finance</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       PHILOSOPHY SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-slate-50" aria-labelledby="philosophy-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
          Unsere Philosophie
        </span>
        <h2 id="philosophy-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-4">
          Was uns auszeichnet
        </h2>
        <p class="text-lg text-slate-600">
          Drei Werte prägen unsere Arbeit und den Umgang mit unseren Kunden.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Value 1 -->
        <article class="bg-white rounded-xl p-8 shadow-card hover:shadow-soft transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-user text-3xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-semibold text-slate-800 mb-3">Persönlichkeit</h3>
          <p class="text-slate-600 leading-relaxed">
            Bei uns gibt es keine Callcenter oder anonymen Ansprechpartner. Sie haben direkten Kontakt zu mir persönlich – von der ersten Beratung bis zum Abschluss. Ich lerne Sie und Ihre Wünsche kennen, um die beste Lösung zu finden.
          </p>
        </article>
        
        <!-- Value 2 -->
        <article class="bg-white rounded-xl p-8 shadow-card hover:shadow-soft transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-lock text-3xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-semibold text-slate-800 mb-3">Vertrauen</h3>
          <p class="text-slate-600 leading-relaxed">
            Ehrlichkeit und Transparenz sind die Grundlage unserer Arbeit. Wir erklären alles verständlich, verstecken keine Kosten und beraten unabhängig – nicht im Sinne einer Bank, sondern im Sinne unserer Kunden.
          </p>
        </article>
        
        <!-- Value 3 -->
        <article class="bg-white rounded-xl p-8 shadow-card hover:shadow-soft transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-6">
            <i class="fa-solid fa-star text-3xl text-primary" aria-hidden="true"></i>
          </div>
          <h3 class="text-xl font-semibold text-slate-800 mb-3">Professionalität</h3>
          <p class="text-slate-600 leading-relaxed">
            Mit fundiertem Fachwissen, Zertifizierungen und jahrelanger Erfahrung garantieren wir höchste Qualität. Wir kennen den Markt, die rechtlichen Rahmenbedingungen und die besten Finanzierungswege.
          </p>
        </article>
      </div>
    </div>
  </section>
  
  <!-- ========================================
       LOCATION / BREMEN SECTION
       ======================================== -->
  <section class="py-20 lg:py-28 bg-white" aria-labelledby="location-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div>
          <span class="inline-block px-4 py-1.5 bg-primary-light text-primary text-sm font-semibold rounded-full mb-4">
            Unser Standort
          </span>
          <h2 id="location-heading" class="text-3xl lg:text-4xl font-bold text-slate-800 mb-6">
            Zuhause in Bremen
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            Bremen ist nicht nur unser Standort – es ist unsere Heimat. Wir kennen die Stadt, die Stadtteile und den Immobilienmarkt wie keine andere. Von Horn über Schwachhausen bis nach Oberneuland – wir wissen, wo Sie am besten wohnen.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Unser Büro befindet sich in der Andreestraße 59 im Herzen von Bremen. Besuchen Sie uns für ein persönliches Gespräch – wir freuen uns auf Sie!
          </p>
          
          <address class="not-italic space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary mt-0.5">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
              </svg>
              <div>
                <p class="font-medium text-slate-800">Dreamhouse Finance</p>
                <p class="text-slate-600">Andreestraße 59</p>
                <p class="text-slate-600">28215 Bremen</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary">
                <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd"/>
              </svg>
              <a href="tel:01622894304" class="text-slate-600 hover:text-primary transition-colors">0162 2894304</a>
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary">
                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
              </svg>
              <a href="mailto:Info@dreamhouse-finance.de" class="text-slate-600 hover:text-primary transition-colors">Info@dreamhouse-finance.de</a>
            </div>
          </address>
          
          <a 
            href="/kontakt/"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-lg hover:bg-primary-hover transition-colors"
          >
            Zeit für dein Eigentum - Kennenlerntermin vereinbaren
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
            </svg>
          </a>
        </div>
        
        <!-- Google Maps -->
        <div class="relative">
          <!-- Placeholder (DSGVO - 2 Klick Lösung) -->
          <div id="map-placeholder" class="aspect-[4/3] rounded-2xl overflow-hidden shadow-xl bg-slate-100 flex flex-col items-center justify-center p-8 text-center">
            <div class="w-16 h-16 bg-primary-light rounded-full flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-primary">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h4 class="font-semibold text-slate-800 mb-2">Google Maps</h4>
            <p class="text-sm text-slate-500 mb-4 max-w-xs">Mit dem Laden der Karte akzeptieren Sie die Datenschutzerklärung von Google.</p>
            <button 
              type="button"
              id="load-map-btn"
              class="px-6 py-2 bg-primary text-white font-medium rounded-lg hover:bg-primary-hover transition-colors"
            >
              Karte anzeigen
            </button>
            <a 
              href="https://maps.google.com/?q=Andreestraße+59+28215+Bremen" 
              target="_blank" 
              rel="noopener noreferrer"
              class="mt-3 text-sm text-primary hover:underline"
            >
              In Google Maps öffnen →
            </a>
          </div>
          
          <!-- Google Maps iframe (wird erst nach Klick geladen) -->
          <div id="map-container" class="hidden aspect-[4/3] rounded-2xl overflow-hidden shadow-xl">
            <iframe 
              id="google-map"
              src=""
              data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2394.2925833841533!2d8.795809!3d53.119291!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b12817981f07b7%3A0x3e5e83f88f3e5e5c!2sAndreestr.%2059%2C%2028215%20Bremen!5e0!3m2!1sde!2sde!4v1700000000000!5m2!1sde!2sde"
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Standort Dreamhouse Finance auf Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <Footer slot="footer" />
  <CookieBanner slot="cookie-banner" />
  <WhatsAppButton slot="whatsapp" />
</Layout>

<script is:inline>
  // Google Maps 2-Klick Lösung
  (function() {
    const loadBtn = document.getElementById('load-map-btn');
    const placeholder = document.getElementById('map-placeholder');
    const container = document.getElementById('map-container');
    const iframe = document.getElementById('google-map');
    
    if (loadBtn && placeholder && container && iframe) {
      loadBtn.addEventListener('click', function() {
        const src = iframe.getAttribute('data-src');
        if (src) {
          iframe.src = src;
          placeholder.classList.add('hidden');
          container.classList.remove('hidden');
        }
      });
    }
  })();
</script>
