---
// Footer Component
const currentYear = new Date().getFullYear();

const footerLinks = {
  leistungen: [
    { label: 'Immobilienmaklerin', href: '/leistungen/' },
    { label: 'Immobilienfinanzierung', href: '/leistungen/' },
    { label: 'Alles aus einer Hand', href: '/leistungen/' },
  ],
  unternehmen: [
    { label: 'Über Uns', href: '/ueber-uns/' },
    { label: 'Kontakt', href: '/kontakt/' },
  ],
  rechtliches: [
    { label: 'Impressum', href: '/impressum/' },
    { label: 'Datenschutz', href: '/datenschutz/' },
  ],
};

const contactInfo = {
  name: 'Esperanza Weiher Muñoz',
  company: 'Dreamhouse Finance',
  address: ['Andreestraße 59', '28215 Bremen'],
  phone: '0162 2894304',
  phoneRaw: '01622894304',
  email: 'Info@dreamhouse-finance.de',
};
---

<footer class="bg-slate-900 text-white" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Main Footer Content -->
    <div class="py-12 lg:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center mb-6" aria-label="Dreamhouse Finance - Zur Startseite">
          <div class="w-16 h-16 rounded-xl overflow-hidden shadow-soft">
            <img 
              src="/images/logo.jpeg" 
              alt="Dreamhouse Finance Logo" 
              class="w-full h-full object-cover"
              width="64"
              height="64"
            />
          </div>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          Ihre Immobilienmaklerin und Finanzierungsexpertin in Bremen. 
          Wir begleiten Sie auf dem Weg zu Ihrer Traumimmobilie – 
          alles aus einer Hand.
        </p>
        
        <!-- Social Links (if needed later) -->
        <div class="flex items-center gap-4">
          <a 
            href={`https://wa.me/49${contactInfo.phoneRaw}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 bg-slate-800 rounded-lg flex items-center justify-center text-slate-400 hover:bg-[#25D366] hover:text-white transition-colors"
            aria-label="WhatsApp"
          >
            <i class="fa-brands fa-whatsapp text-lg"></i>
          </a>
        </div>
      </div>
      
      <!-- Leistungen -->
      <div>
        <h3 class="font-semibold text-white mb-4">Leistungen</h3>
        <ul class="space-y-3">
          {footerLinks.leistungen.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-slate-400 text-sm hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Unternehmen -->
      <div>
        <h3 class="font-semibold text-white mb-4">Unternehmen</h3>
        <ul class="space-y-3">
          {footerLinks.unternehmen.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-slate-400 text-sm hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="font-semibold text-white mb-4 mt-6">Rechtliches</h3>
        <ul class="space-y-3">
          {footerLinks.rechtliches.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-slate-400 text-sm hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Kontakt -->
      <div>
        <h3 class="font-semibold text-white mb-4">Kontakt</h3>
        <address class="not-italic space-y-3">
          <p class="text-slate-400 text-sm">
            <strong class="text-white block">{contactInfo.name}</strong>
            {contactInfo.company}
          </p>
          <p class="text-slate-400 text-sm">
            {contactInfo.address[0]}<br />
            {contactInfo.address[1]}
          </p>
          <p>
            <a 
              href={`tel:${contactInfo.phoneRaw}`}
              class="text-slate-400 text-sm hover:text-primary transition-colors inline-flex items-center gap-2"
              aria-label={`Anrufen: ${contactInfo.phone}`}
            >
              <i class="fa-solid fa-phone text-sm"></i>
              {contactInfo.phone}
            </a>
          </p>
          <p>
            <a 
              href={`mailto:${contactInfo.email}`}
              class="text-slate-400 text-sm hover:text-primary transition-colors inline-flex items-center gap-2"
              aria-label={`E-Mail: ${contactInfo.email}`}
            >
              <i class="fa-solid fa-envelope text-sm"></i>
              {contactInfo.email}
            </a>
          </p>
        </address>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="py-6 border-t border-slate-800">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-slate-500 text-sm text-center md:text-left">
          © {currentYear} Dreamhouse Finance. Alle Rechte vorbehalten.
        </p>
        <p class="text-slate-600 text-xs">
          Einzelunternehmen · Inhaberin: {contactInfo.name}
        </p>
      </div>
    </div>
  </div>
</footer>
